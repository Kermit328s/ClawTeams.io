{
  "name": "clawteams",
  "version": "0.1.0",
  "private": true,
  "description": "ClawTeams - Team collaboration operating system that eliminates context drift",
  "scripts": {
    "test": "jest --passWithNoTests",
    "test:e2e": "jest --testPathPattern=tests/e2e --passWithNoTests --testTimeout=30000",
    "test:integration": "jest --testPathPattern=tests/integration --passWithNoTests",
    "test:unit": "jest --testPathIgnorePatterns='tests/(integration|e2e)' --passWithNoTests",
    "lint": "eslint src/ tests/",
    "typecheck": "tsc --noEmit",
    "build": "tsc -b"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.500.0",
    "@aws-sdk/s3-request-presigner": "^3.500.0",
    "@fastify/cors": "^9.0.0",
    "better-sqlite3": "^11.0.0",
    "fastify": "^4.25.0",
    "neo4j-driver": "^5.20.0",
    "pg": "^8.12.0",
    "ws": "^8.16.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.0",
    "@types/jest": "^29.5.0",
    "@types/node": "^20.0.0",
    "@types/pg": "^8.12.0",
    "@types/ws": "^8.16.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.2.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.5.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
