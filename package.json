{
  "name": "clawteams",
  "version": "0.1.0",
  "private": true,
  "description": "ClawTeams - Team collaboration operating system that eliminates context drift",
  "workspaces": [
    "src/infra",
    "src/brain",
    "src/workflow",
    "src/connector",
    "src/claw-sdk",
    "src/frontend"
  ],
  "scripts": {
    "test": "jest --passWithNoTests",
    "test:integration": "jest --testPathPattern=tests/integration --passWithNoTests",
    "test:unit": "jest --testPathIgnorePatterns=tests/integration --passWithNoTests",
    "lint": "eslint src/ tests/",
    "typecheck": "tsc --noEmit",
    "build": "tsc -b"
  },
  "devDependencies": {
    "@types/jest": "^29.5.0",
    "@types/node": "^20.0.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.2.0",
    "typescript": "^5.5.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
